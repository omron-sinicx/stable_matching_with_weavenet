# Build context exclusions
# Keep the context small for `docker compose build` — Dockerfile only needs
# requirements.txt; everything else is bind-mounted at runtime.
.git/
data/
logs/
worktrees/
docs/papers/2310.12515_source/figures/
**/__pycache__/
**/.pytest_cache/
**/.mypy_cache/
**/.venv/
**/.DS_Store
*.tar
*.tar.gz
